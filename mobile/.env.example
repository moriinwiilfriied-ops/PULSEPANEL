# Copier en .env et remplir avec les valeurs du projet Supabase (Project Settings → API).
# Ne pas commiter .env (déjà dans .gitignore).

EXPO_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=votre_anon_public_key

# Afficher les blocs debug (SOURCE, DEV, campaigns loaded, user_id, validation dashboard, badge SB/MOCK) en Expo Go. 0 = masqué (défaut), 1 = affiché.
EXPO_PUBLIC_SHOW_DEBUG_UI=0
