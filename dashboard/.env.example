# Copier en .env.local et remplir avec les valeurs du projet Supabase (Project Settings → API).
# Ne pas commiter .env.local (déjà dans .gitignore).

NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_secret

# Stripe (mode test : clés sk_test_... et pk_test_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
